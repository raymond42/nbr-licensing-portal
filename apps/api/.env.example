# Runtime
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://nbr:nbr@localhost:5432/nbr_licensing?schema=public

# Auth
JWT_SECRET=replace-me-with-a-strong-secret
JWT_EXPIRES_IN=3600s

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_BYTES=10485760

# Seed (required by `pnpm seed`; rejected if missing or password < 12 chars)
SEED_ADMIN_EMAIL=admin@nbr.local
SEED_ADMIN_PASSWORD=replace-with-strong-password
