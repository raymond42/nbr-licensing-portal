# Runtime
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://nbr:nbr@localhost:5432/nbr_licensing?schema=public

# Auth
JWT_SECRET=replace-me-with-a-strong-secret
JWT_EXPIRES_IN=3600s

# Uploads (5MB default; must match server enforcement)
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_BYTES=5242880

# Seed (optional - used by `pnpm --filter @nbr/api run seed` / `prisma db seed`)
# When set, must be at least 12 characters. If unset, seed uses a documented
# local-only default; never use defaults in production.
# SEED_DEFAULT_PASSWORD=
