generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  APPLICANT
  REVIEWER
  APPROVER
  ADMIN
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  INFO_REQUESTED
  RESUBMITTED
  REVIEW_COMPLETED
  APPROVED
  REJECTED
}

enum DocumentType {
  CERTIFICATE_OF_INCORPORATION
  ARTICLES_OF_ASSOCIATION
  AUDITED_FINANCIAL_STATEMENTS
  BUSINESS_PLAN
  TAX_CLEARANCE
  DIRECTOR_IDENTIFICATION
  OTHER
}

enum AuditAction {
  APPLICATION_CREATED
  APPLICATION_UPDATED
  STATUS_CHANGED
  DOCUMENT_UPLOADED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  fullName     String
  passwordHash String
  role         Role     @default(APPLICANT)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applications                  Application[]          @relation("ApplicantApplications")
  applicationsReviewCompleted   Application[]          @relation("ReviewCompletedBy")
  uploadedDocuments             ApplicationDocument[]
  auditLogs                     AuditLog[]

  @@map("users")
}

model Application {
  id                       String            @id @default(uuid())
  applicantId              String
  applicant                User              @relation("ApplicantApplications", fields: [applicantId], references: [id])
  institutionName          String
  licenseCategory          String
  description              String            @default("") @db.Text
  status                   ApplicationStatus @default(DRAFT)
  version                  Int               @default(0)
  reviewCompletedByUserId  String?
  reviewCompletedBy        User?             @relation("ReviewCompletedBy", fields: [reviewCompletedByUserId], references: [id])
  submittedAt              DateTime?
  decidedAt                DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  documents ApplicationDocument[]
  auditLogs AuditLog[]

  @@index([applicantId])
  @@index([status])
  @@map("applications")
}

model ApplicationDocument {
  id               String       @id @default(uuid())
  applicationId    String
  application      Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type             DocumentType
  logicalKey       String
  version          Int
  storagePath      String
  originalFileName String
  mimeType         String
  sizeBytes        Int
  checksum         String?
  uploadedByUserId String
  uploadedBy       User         @relation(fields: [uploadedByUserId], references: [id])
  createdAt        DateTime     @default(now())

  @@unique([applicationId, logicalKey, version])
  @@index([applicationId])
  @@map("application_documents")
}

model AuditLog {
  id              String             @id @default(uuid())
  applicationId   String
  application     Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  actorUserId     String
  actor           User               @relation(fields: [actorUserId], references: [id])
  action          AuditAction
  previousStatus  ApplicationStatus?
  nextStatus      ApplicationStatus?
  metadata        Json?
  integrityHash   String?
  createdAt       DateTime           @default(now())

  @@index([applicationId, createdAt])
  @@index([createdAt, id])
  @@map("audit_logs")
}
